                        ))}
                      </div>
                      {showInsights && (
                        <motion.span key={insightIndex} initial={{ opacity: 0 }} animate={{ opacity: 1 }}
                          className="text-white/50 text-[9px] tracking-widest uppercase">
                          insight {insightIndex + 1}/{project.insights.length}
