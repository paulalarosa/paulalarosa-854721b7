                </motion.div>
              )}
            </AnimatePresence>
          </div>

          <div className="absolute bottom-2 left-1/2 -translate-x-1/2 rounded-full"
            style={{ width: 110, height: 4, backgroundColor: 'rgba(255,255,255,0.18)' }} />
