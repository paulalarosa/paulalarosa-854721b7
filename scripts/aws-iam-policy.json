{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PortfolioBucketReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::paulalarosa-bucket2"
    },
    {
      "Sid": "PortfolioObjectsReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:PutObjectAcl"
      ],
      "Resource": "arn:aws:s3:::paulalarosa-bucket2/*"
    },
    {
      "Sid": "PortfolioCloudFrontInvalidate",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetInvalidation",
        "cloudfront:ListInvalidations"
      ],
      "Resource": "arn:aws:cloudfront::751647213647:distribution/EQ7ALXF37OFQX"
    }
  ]
}
